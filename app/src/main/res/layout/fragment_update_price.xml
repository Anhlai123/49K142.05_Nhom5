<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/primary">

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="24dp"
            android:text="Cập nhật bảng giá"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageButton
            android:id="@+id/btn_close"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginEnd="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_close"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/card_background"
                android:padding="16dp">

                <TextView
                    android:id="@+id/label_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mã bảng giá"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/tv_price_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_search_bar"
                    android:paddingHorizontal="12dp"
                    android:paddingVertical="4dp"
                    android:text="BG003"
                    android:textColor="#212121"
                    android:textStyle="bold"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/label_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Tên bảng giá *"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/tv_price_id" />

                <EditText
                    android:id="@+id/et_price_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="Nhập tên bảng giá"
                    android:paddingHorizontal="12dp"
                    android:text="Sân Cầu lông - Tiêu chuẩn"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/label_name" />

                <TextView
                    android:id="@+id/label_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Loại sân áp dụng *"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_price_name" />

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_select_type"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field"
                    android:paddingHorizontal="16dp"
                    app:layout_constraintTop_toBottomOf="@id/label_type">

                    <TextView
                        android:id="@+id/tv_selected_court_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sân Cầu lông"
                        android:textColor="#212121"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:rotation="90"
                        android:src="@drawable/ic_back"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#9E9E9E" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/label_scope"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Phạm vi áp dụng"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_select_type" />

                <LinearLayout
                    android:id="@+id/layout_scope_selection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/label_scope">

                    <TextView
                        android:id="@+id/btn_scope_all"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_active"
                        android:gravity="center"
                        android:text="✓ Tất cả sân"
                        android:textColor="@color/primary"
                        android:textStyle="bold" />

                    <TextView
                        android:id="@+id/btn_scope_specific"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_inactive"
                        android:gravity="center"
                        android:text="Sân cụ thể"
                        android:textColor="#757575"
                        android:textStyle="bold" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_specific_courts"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="12dp"
                    android:orientation="vertical"
                    android:visibility="gone"
                    app:layout_constraintTop_toBottomOf="@id/layout_scope_selection">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Chọn sân cụ thể"
                        android:textColor="#212121"
                        android:textSize="12sp"
                        android:textStyle="bold" />

                    <HorizontalScrollView
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:scrollbars="none">

                        <LinearLayout
                            android:id="@+id/layout_court_chips"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:orientation="horizontal" />
                    </HorizontalScrollView>

                    <TextView
                        android:id="@+id/tv_selected_courts_summary"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="8dp"
                        android:text="Chưa chọn sân nào"
                        android:textColor="#757575"
                        android:textSize="12sp" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_dates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/layout_specific_courts">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngày hiệu lực *" android:textSize="13sp" android:textStyle="bold"/>
                        <EditText android:id="@+id/et_start_date" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:background="@drawable/bg_input_field" android:clickable="true" android:drawableEnd="@android:drawable/ic_menu_my_calendar" android:focusable="false" android:hint="dd/MM/yyyy" android:paddingHorizontal="12dp" android:textSize="14sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="16dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngày kết thúc" android:textSize="13sp" android:textStyle="bold"/>
                        <EditText android:id="@+id/et_end_date" android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="8dp" android:background="@drawable/bg_input_field" android:clickable="true" android:drawableEnd="@android:drawable/ic_menu_my_calendar" android:focusable="false" android:hint="Vô thời hạn" android:paddingHorizontal="12dp" android:textSize="14sp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/label_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Ngày áp dụng *"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layout_dates" />

                <LinearLayout
                    android:id="@+id/layout_days_selection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/label_days">
                    <TextView android:id="@+id/day_t2" style="@style/DayPillStyle" android:background="@drawable/bg_day_pill_inactive" android:text="T2" android:textColor="@color/inactive" />
                    <TextView android:id="@+id/day_t3" style="@style/DayPillStyle" android:background="@drawable/bg_day_pill_inactive" android:text="T3" android:textColor="@color/inactive" />
                    <TextView android:id="@+id/day_t4" style="@style/DayPillStyle" android:background="@drawable/bg_day_pill_inactive" android:text="T4" android:textColor="@color/inactive" />
                    <TextView android:id="@+id/day_t5" style="@style/DayPillStyle" android:background="@drawable/bg_day_pill_inactive" android:text="T5" android:textColor="@color/inactive" />
                    <TextView android:id="@+id/day_t6" style="@style/DayPillStyle" android:background="@drawable/bg_day_pill_inactive" android:text="T6" android:textColor="@color/inactive" />
                    <TextView android:id="@+id/day_t7" style="@style/DayPillStyle" android:background="@drawable/bg_day_pill_inactive" android:text="T7" android:textColor="@color/inactive" />
                    <TextView android:id="@+id/day_cn" style="@style/DayPillStyle" android:background="@drawable/bg_day_pill_inactive" android:text="CN" android:textColor="@color/inactive" />
                </LinearLayout>

                <TextView
                    android:id="@+id/label_frames"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="Khung giờ &amp; đơn giá *"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layout_days_selection" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_add_frame"
                    android:layout_width="wrap_content"
                    android:layout_height="40dp"
                    android:backgroundTint="@color/primary"
                    android:text="+ Thêm khung giờ"
                    android:textAllCaps="false"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    app:cornerRadius="20dp"
                    app:layout_constraintBottom_toBottomOf="@id/label_frames"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="@id/label_frames" />

                <!-- Time Frame Item -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:background="@drawable/bg_search_bar"
                    android:padding="16dp"
                    app:layout_constraintTop_toBottomOf="@id/label_frames">

                    <TextView
                        android:id="@+id/tv_frame_label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Khung giờ 1"
                        android:textColor="#212121"
                        android:textSize="14sp"
                        android:textStyle="bold"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="18dp"
                        android:layout_height="18dp"
                        android:src="@drawable/ic_close"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#FF3B30" />

                    <LinearLayout
                        android:id="@+id/layout_time_inputs"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/tv_frame_label">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giờ bắt đầu" android:textSize="12sp" android:textColor="#757575"/>
                            <EditText android:id="@+id/et_start_time" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:clickable="true" android:drawableEnd="@drawable/ic_clock_green" android:focusable="false" android:hint="00:00" android:paddingHorizontal="12dp" android:textSize="13sp" app:drawableTint="#9E9E9E"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giờ kết thúc" android:textSize="12sp" android:textColor="#757575"/>
                            <EditText android:id="@+id/et_end_time" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:clickable="true" android:drawableEnd="@drawable/ic_clock_green" android:focusable="false" android:hint="00:00" android:paddingHorizontal="12dp" android:textSize="13sp" app:drawableTint="#9E9E9E"/>
                        </LinearLayout>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:layout_marginTop="12dp"
                        android:orientation="horizontal"
                        app:layout_constraintTop_toBottomOf="@id/layout_time_inputs">

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đơn giá (đ/giờ)" android:textSize="12sp" android:textColor="#757575"/>
                            <EditText android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:text="200000" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="wrap_content"
                            android:layout_marginStart="12dp"
                            android:layout_weight="1"
                            android:orientation="vertical">
                            <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ghi chú" android:textSize="12sp" android:textColor="#757575"/>
                            <EditText android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:text="Giờ thường" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                        </LinearLayout>
                    </LinearLayout>
                </androidx.constraintlayout.widget.ConstraintLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>
        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:padding="16dp"
        android:orientation="horizontal">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Huỷ"
            android:textAllCaps="false"
            android:textColor="#212121"
            app:cornerRadius="16dp"
            app:strokeColor="#DEE2E6" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/primary"
            android:text="Lưu cập nhật"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="16dp"
            app:elevation="0dp" />
    </LinearLayout>

</LinearLayout>