<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="16dp"
    app:cardBackgroundColor="@color/white"
    app:cardCornerRadius="24dp"
    app:cardElevation="2dp"
    app:strokeWidth="0dp">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="16dp">

        <!-- Icon Sân -->
        <View
            android:id="@+id/icon_bg"
            android:layout_width="44dp"
            android:layout_height="44dp"
            android:background="@drawable/bg_circle_light_green"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <ImageView
            android:layout_width="22dp"
            android:layout_height="22dp"
            android:src="@drawable/ic_building"
            app:layout_constraintBottom_toBottomOf="@id/icon_bg"
            app:layout_constraintEnd_toEndOf="@id/icon_bg"
            app:layout_constraintStart_toStartOf="@id/icon_bg"
            app:layout_constraintTop_toTopOf="@id/icon_bg"
            app:tint="@color/primary" />

        <!-- Tên và Mã sân -->
        <TextView
            android:id="@+id/tv_court_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="12dp"
            android:text="Sân B1"
            android:textColor="#212121"
            android:textSize="16sp"
            android:textStyle="bold"
            app:layout_constraintStart_toEndOf="@id/icon_bg"
            app:layout_constraintTop_toTopOf="@id/icon_bg" />

        <TextView
            android:id="@+id/tv_court_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginStart="8dp"
            android:text="SAN001"
            android:textColor="#BDBDBD"
            android:textSize="13sp"
            app:layout_constraintBottom_toBottomOf="@id/tv_court_name"
            app:layout_constraintStart_toEndOf="@id/tv_court_name" />

        <TextView
            android:id="@+id/tv_court_type"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sân bóng đá"
            android:textColor="#9E9E9E"
            android:textSize="14sp"
            app:layout_constraintStart_toStartOf="@id/tv_court_name"
            app:layout_constraintTop_toBottomOf="@id/tv_court_name" />

        <!-- Badge Trạng thái -->
        <TextView
            android:id="@+id/tv_status"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:background="@drawable/status_bg_available"
            android:paddingHorizontal="10dp"
            android:paddingVertical="4dp"
            android:text="Sẵn sàng"
            android:textColor="#00A63E"
            android:textSize="11sp"
            android:textStyle="bold"
            app:layout_constraintEnd_toEndOf="parent"
            app:layout_constraintTop_toTopOf="parent" />

        <!-- Nút Sửa & Xóa -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="16dp"
            android:orientation="horizontal"
            app:layout_constraintTop_toBottomOf="@id/tv_court_type">

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_edit"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginEnd="6dp"
                android:layout_weight="1"
                android:text="Sửa"
                android:textAllCaps="false"
                android:textColor="#007AFF"
                app:backgroundTint="#F0F7FF"
                app:cornerRadius="12dp"
                app:icon="@drawable/ic_edit"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconTint="#007AFF" />

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_delete"
                style="@style/Widget.MaterialComponents.Button.UnelevatedButton"
                android:layout_width="0dp"
                android:layout_height="48dp"
                android:layout_marginStart="6dp"
                android:layout_weight="1"
                android:text="Xóa"
                android:textAllCaps="false"
                android:textColor="#FF3B30"
                app:backgroundTint="#FFF5F5"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconGravity="textStart"
                app:iconSize="18dp"
                app:iconTint="#FF3B30" />
        </LinearLayout>
    </androidx.constraintlayout.widget.ConstraintLayout>
</com.google.android.material.card.MaterialCardView>