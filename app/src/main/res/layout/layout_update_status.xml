<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:background="@drawable/bg_bottom_sheet"
    android:orientation="vertical"
    android:padding="16dp">

    <!-- Header -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="@drawable/bg_button_outline_green"
        android:gravity="center"
        android:text="Cập nhật trạng thái"
        android:textColor="#00A63E"
        android:textSize="18sp"
        android:textStyle="bold" />

    <!-- Status Options -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:background="@drawable/bg_order_card"
        android:orientation="vertical">

        <TextView
            android:id="@+id/status_pending"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="Chờ xác nhận"
            android:textColor="#1A202C"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E2E8F0" />

        <TextView
            android:id="@+id/status_completed"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="Hoàn tất"
            android:textColor="#1A202C"
            android:textSize="16sp" />

        <View
            android:layout_width="match_parent"
            android:layout_height="0.5dp"
            android:background="#E2E8F0" />

        <TextView
            android:id="@+id/status_cancelled"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:gravity="center_vertical"
            android:paddingHorizontal="20dp"
            android:text="Hủy"
            android:textColor="#1A202C"
            android:textSize="16sp" />
    </LinearLayout>

</LinearLayout>
