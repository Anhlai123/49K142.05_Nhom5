<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F8F9FA"
    android:orientation="vertical">

    <!-- Header -->
    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="80dp"
        android:background="@color/primary">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="48dp"
            android:layout_height="48dp"
            android:layout_marginStart="8dp"
            android:background="?attr/selectableItemBackgroundBorderless"
            android:src="@drawable/ic_back"
            app:layout_constraintBottom_toBottomOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintTop_toTopOf="parent"
            app:tint="@color/white" />

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Thêm bảng giá mới"
            android:textColor="@color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            app:layout_constraintBottom_toBottomOf="@id/btn_back"
            app:layout_constraintStart_toEndOf="@id/btn_back"
            app:layout_constraintTop_toTopOf="@id/btn_back" />
    </androidx.constraintlayout.widget.ConstraintLayout>

    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="THÔNG TIN CHUNG"
                android:textColor="#1B4332"
                android:textSize="13sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_background"
                android:padding="16dp">

                <TextView
                    android:id="@+id/label_id"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Mã bảng giá"
                    android:textColor="#757575"
                    android:textSize="14sp"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:background="@drawable/bg_search_bar"
                    android:paddingHorizontal="8dp"
                    android:paddingVertical="4dp"
                    android:text="BG001"
                    android:textColor="#9E9E9E"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <TextView
                    android:id="@+id/label_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Tên bảng giá *"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/label_id" />

                <EditText
                    android:id="@+id/et_price_name"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_input_field"
                    android:hint="VD: Bảng giá ngày thường"
                    android:paddingHorizontal="12dp"
                    android:textSize="14sp"
                    app:layout_constraintTop_toBottomOf="@id/label_name" />

                <TextView
                    android:id="@+id/label_type"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Loại sân"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/et_price_name" />

                <!-- Custom Dropdown for Court Type -->
                <androidx.constraintlayout.widget.ConstraintLayout
                    android:id="@+id/btn_select_court_type"
                    android:layout_width="match_parent"
                    android:layout_height="48dp"
                    android:layout_marginTop="8dp"
                    android:background="@drawable/bg_pill_active"
                    android:paddingHorizontal="16dp"
                    app:layout_constraintTop_toBottomOf="@id/label_type">

                    <TextView
                        android:id="@+id/tv_selected_court_type"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Sân cầu lông"
                        android:textColor="#212121"
                        android:textSize="14sp"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintTop_toTopOf="parent" />

                    <ImageView
                        android:layout_width="20dp"
                        android:layout_height="20dp"
                        android:rotation="90"
                        android:src="@drawable/ic_back"
                        app:layout_constraintBottom_toBottomOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        app:layout_constraintTop_toTopOf="parent"
                        app:tint="#9E9E9E" />
                </androidx.constraintlayout.widget.ConstraintLayout>

                <TextView
                    android:id="@+id/label_scope"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Phạm vi áp dụng"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/btn_select_court_type" />

                <LinearLayout
                    android:id="@+id/layout_scope_selection"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/label_scope">

                    <TextView
                        android:id="@+id/pill_all_scope"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginEnd="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_active"
                        android:gravity="center"
                        android:text="✓ Tất cả sân"
                        android:textColor="@color/primary"
                        android:clickable="true"
                        android:focusable="true" />

                    <TextView
                        android:id="@+id/pill_specific_scope"
                        android:layout_width="0dp"
                        android:layout_height="44dp"
                        android:layout_marginStart="8dp"
                        android:layout_weight="1"
                        android:background="@drawable/bg_pill_inactive"
                        android:gravity="center"
                        android:text="Sân cụ thể"
                        android:textColor="#757575"
                        android:clickable="true"
                        android:focusable="true" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/layout_dates"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/layout_scope_selection">

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngày hiệu lực" android:textSize="12sp" android:textStyle="bold"/>
                        <EditText android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:hint="mm/dd/yyyy" android:drawableEnd="@android:drawable/ic_menu_my_calendar" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="0dp"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="12dp"
                        android:layout_weight="1"
                        android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ngày kết thúc" android:textSize="12sp" android:textStyle="bold"/>
                        <EditText android:layout_width="match_parent" android:layout_height="48dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:hint="mm/dd/yyyy" android:drawableEnd="@android:drawable/ic_menu_my_calendar" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>

                <TextView
                    android:id="@+id/label_days"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:text="Ngày áp dụng trong tuần"
                    android:textColor="#212121"
                    android:textSize="12sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toBottomOf="@id/layout_dates" />

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="8dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/label_days">
                    <TextView android:id="@+id/day_t2" style="@style/DayPillStyle" android:text="T2" android:background="@drawable/bg_day_pill_inactive" android:textColor="@color/inactive" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/day_t3" style="@style/DayPillStyle" android:text="T3" android:background="@drawable/bg_day_pill_inactive" android:textColor="@color/inactive" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/day_t4" style="@style/DayPillStyle" android:text="T4" android:background="@drawable/bg_day_pill_inactive" android:textColor="@color/inactive" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/day_t5" style="@style/DayPillStyle" android:text="T5" android:background="@drawable/bg_day_pill_inactive" android:textColor="@color/inactive" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/day_t6" style="@style/DayPillStyle" android:text="T6" android:background="@drawable/bg_day_pill_inactive" android:textColor="@color/inactive" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/day_t7" style="@style/DayPillStyle" android:text="T7" android:background="@drawable/bg_day_pill_inactive" android:textColor="@color/inactive" android:clickable="true" android:focusable="true"/>
                    <TextView android:id="@+id/day_cn" style="@style/DayPillStyle" android:text="CN" android:background="@drawable/bg_day_pill_inactive" android:textColor="@color/inactive" android:clickable="true" android:focusable="true"/>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:text="CHI TIẾT KHUNG GIỜ"
                android:textColor="#1B4332"
                android:textSize="13sp"
                android:textStyle="bold" />

            <androidx.constraintlayout.widget.ConstraintLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="12dp"
                android:background="@drawable/card_background"
                android:padding="16dp">

                <TextView
                    android:id="@+id/tv_frame_title"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Khung giờ 1"
                    android:textColor="#212121"
                    android:textSize="14sp"
                    android:textStyle="bold"
                    app:layout_constraintStart_toStartOf="parent"
                    app:layout_constraintTop_toTopOf="parent" />

                <ImageView
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:src="@drawable/ic_close"
                    app:layout_constraintEnd_toEndOf="parent"
                    app:layout_constraintTop_toTopOf="parent"
                    app:tint="#FFCDD2" />

                <LinearLayout
                    android:id="@+id/layout_times"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/tv_frame_title">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giờ bắt đầu" android:textSize="11sp" android:textColor="#757575"/>
                        <EditText android:id="@+id/et_start_time" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:hint="HH:mm" android:inputType="time" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Giờ kết thúc" android:textSize="11sp" android:textColor="#757575"/>
                        <EditText android:id="@+id/et_end_time" android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:hint="HH:mm" android:inputType="time" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="16dp"
                    android:orientation="horizontal"
                    app:layout_constraintTop_toBottomOf="@id/layout_times">

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Đơn giá (đ/giờ)" android:textSize="11sp" android:textColor="#757575"/>
                        <EditText android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:text="150000" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>

                    <LinearLayout android:layout_width="0dp" android:layout_height="wrap_content" android:layout_marginStart="12dp" android:layout_weight="1" android:orientation="vertical">
                        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content" android:text="Ghi chú" android:textSize="11sp" android:textColor="#757575"/>
                        <EditText android:layout_width="match_parent" android:layout_height="44dp" android:layout_marginTop="4dp" android:background="@drawable/bg_input_field" android:hint="VD: Giờ vàng" android:paddingHorizontal="12dp" android:textSize="13sp"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.constraintlayout.widget.ConstraintLayout>

            <com.google.android.material.button.MaterialButton
                android:id="@+id/btn_add_frame"
                style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:layout_marginTop="16dp"
                android:text="Thêm khung giờ"
                android:textAllCaps="false"
                android:textColor="@color/primary"
                app:cornerRadius="12dp"
                app:icon="@android:drawable/ic_input_add"
                app:iconGravity="textStart"
                app:iconTint="@color/primary"
                app:strokeColor="@color/primary"
                app:strokeWidth="1dp"
                android:stateListAnimator="@null" />

        </LinearLayout>
    </ScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/white"
        android:orientation="horizontal"
        android:padding="16dp">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_cancel"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginEnd="8dp"
            android:layout_weight="1"
            android:text="Huỷ"
            android:textAllCaps="false"
            android:textColor="#212121"
            app:cornerRadius="16dp"
            app:strokeColor="#DEE2E6" />

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btn_save"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_marginStart="8dp"
            android:layout_weight="1"
            android:backgroundTint="@color/primary"
            android:text="Lưu Bảng giá"
            android:textAllCaps="false"
            android:textColor="@color/white"
            app:cornerRadius="16dp"
            app:elevation="0dp" />
    </LinearLayout>

</LinearLayout>